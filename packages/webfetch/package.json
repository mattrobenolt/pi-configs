{
  "name": "webfetch",
  "version": "0.0.0",
  "private": true,
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "test": "node --experimental-strip-types --test index.test.ts",
    "eval": "node --experimental-strip-types eval.ts",
    "fmt": "oxfmt index.ts core.ts config.ts narrow.ts index.test.ts eval.ts",
    "fmt:check": "oxfmt index.ts core.ts config.ts narrow.ts index.test.ts eval.ts --check",
    "lint": "oxlint index.ts core.ts config.ts narrow.ts index.test.ts eval.ts"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "catalog:",
    "@earendil-works/pi-coding-agent": "catalog:",
    "@mattrobenolt/pi-core": "workspace:*",
    "defuddle": "catalog:",
    "turndown": "catalog:",
    "typebox": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/turndown": "catalog:"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
}
