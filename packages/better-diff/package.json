{
  "name": "better-diff",
  "version": "0.0.0",
  "private": true,
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "scripts": {
    "fmt": "oxfmt index.ts",
    "fmt:check": "oxfmt index.ts --check",
    "lint": "oxlint index.ts",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@pierre/diffs": "^1.1.0"
  },
  "devDependencies": {
    "oxfmt": "^0.46.0",
    "oxlint": "^1.57.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
}
