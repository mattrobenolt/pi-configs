{
  "name": "memory-extension",
  "version": "0.0.0",
  "private": true,
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "fmt": "oxfmt index.ts lib",
    "fmt:check": "oxfmt index.ts lib --check",
    "lint": "oxlint index.ts lib"
  },
  "dependencies": {
    "@mattrobenolt/pi-core": "workspace:*",
    "typebox": "catalog:"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
}
