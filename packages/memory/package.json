{
  "name": "memory-extension",
  "version": "0.0.0",
  "private": true,
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "fmt": "oxfmt index.ts lib",
    "fmt:check": "oxfmt index.ts lib --check",
    "lint": "oxlint index.ts lib"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.70.2",
    "@mariozechner/pi-ai": "^0.70.2",
    "@mariozechner/pi-coding-agent": "^0.70.2",
    "typebox": "^1.1.33"
  },
  "devDependencies": {
    "oxfmt": "^0.46.0",
    "oxlint": "^1.57.0",
    "typescript": "^6.0.3"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
}
