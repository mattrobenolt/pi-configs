{
  "name": "slack-extension",
  "version": "0.0.0",
  "private": true,
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "fmt": "oxfmt index.ts",
    "fmt:check": "oxfmt index.ts --check",
    "lint": "oxlint index.ts"
  },
  "dependencies": {
    "@mattrobenolt/pi-core": "file:../pi-core",
    "hysnappy": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
}
