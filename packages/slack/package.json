{
  "name": "pi-slack",
  "version": "0.0.0",
  "private": true,
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "fmt": "oxfmt index.ts",
    "fmt:check": "oxfmt index.ts --check",
    "lint": "oxlint index.ts"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "catalog:",
    "@mattrobenolt/pi-core": "workspace:*",
    "hysnappy": "catalog:",
    "typebox": "catalog:"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
}
